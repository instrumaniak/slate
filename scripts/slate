#!/bin/bash
# Slate launcher script
# Usage: ./scripts/slate [path]
#   - No args: open blank window, restore last folder
#   - slate .   : open current directory
#   - slate <path> : open specified file or folder

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR/.."
python3 -m slate "$@"